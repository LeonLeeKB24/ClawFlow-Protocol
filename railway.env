# CFP Railway 部署配置

# Railway 应用配置
RAILWAY_PROJECT_NAME=clawflow-protocol
RAILWAY_SERVICE_NAME=api-service

# Railway 部署脚本
RAILWAY_DEPLOY_CMD="npm install && npm start"

# 环境变量配置
RAILWAY_ENVIRONMENT=production
RAILWAY_REGION=us-east # 可选: us-east, eu-west, asia-south

# 数据库配置
RAILWAY_DATABASE_URL=postgresql://postgres:password@localhost:5432/clawflow_prod

# 构建配置
RAILWAY_BUILD_CMD="npm install"
RAILWAY_START_CMD="npm start"

# 健康检查
RAILWAY_HEALTHCHECK_PATH=/health

# 自定义域名
RAILWAY_CUSTOM_DOMAIN=clawflow-ai.xyz